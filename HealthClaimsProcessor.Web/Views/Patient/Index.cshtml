@model IEnumerable<Patient>
@{
    ViewBag.Title = "Patients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people"></i> Patients</h2>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Patient
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Date of Birth</th>
                <th>SSN</th>
                <th>Insurance Policy #</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var patient in Model)
                {
                    <tr>
                        <td>
                            <a href="@Url.Action("Details", new { id = patient.PatientId })">
                                @patient.LastName, @patient.FirstName
                            </a>
                        </td>
                        <td>@patient.DateOfBirth.ToString("MM/dd/yyyy")</td>
                        <td>@Html.DisplayFor(modelItem => patient.SSN)</td>
                        <td>@Html.DisplayFor(modelItem => patient.InsurancePolicyNumber)</td>
                        <td>@Html.DisplayFor(modelItem => patient.Phone)</td>
                        <td>
                            @if (patient.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("Details", new { id = patient.PatientId })" class="btn btn-sm btn-outline-primary" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="@Url.Action("Edit", new { id = patient.PatientId })" class="btn btn-sm btn-outline-secondary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No patients found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
