@model IEnumerable<Claim>
@{
    ViewBag.Title = "Claims";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-medical"></i> Claims</h2>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Claim
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Claim Number</th>
                <th>Patient</th>
                <th>Provider</th>
                <th>Service Date</th>
                <th>Status</th>
                <th class="text-end">Total Charge</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var claim in Model)
                {
                    <tr>
                        <td>
                            <a href="@Url.Action("Details", new { id = claim.ClaimId })">
                                @Html.DisplayFor(modelItem => claim.ClaimNumber)
                            </a>
                        </td>
                        <td>
                            @if (claim.Patient != null)
                            {
                                @claim.Patient.LastName@:, @claim.Patient.FirstName
                            }
                        </td>
                        <td>
                            @if (claim.Provider != null)
                            {
                                @Html.DisplayFor(modelItem => claim.Provider.Name)
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => claim.ServiceDateFrom)</td>
                        <td>
                            @{
                                string badgeClass;
                                switch (claim.Status)
                                {
                                    case ClaimStatus.Approved:
                                    case ClaimStatus.Paid:
                                        badgeClass = "bg-success";
                                        break;
                                    case ClaimStatus.Denied:
                                    case ClaimStatus.Cancelled:
                                        badgeClass = "bg-danger";
                                        break;
                                    case ClaimStatus.UnderReview:
                                    case ClaimStatus.PendingInformation:
                                        badgeClass = "bg-warning text-dark";
                                        break;
                                    case ClaimStatus.Submitted:
                                        badgeClass = "bg-info text-dark";
                                        break;
                                    case ClaimStatus.PartiallyApproved:
                                        badgeClass = "bg-warning";
                                        break;
                                    default:
                                        badgeClass = "bg-secondary";
                                        break;
                                }
                            }
                            <span class="badge @badgeClass">@claim.Status</span>
                        </td>
                        <td class="text-end">@claim.TotalChargeAmount.ToString("C")</td>
                        <td>
                            <a href="@Url.Action("Details", new { id = claim.ClaimId })" class="btn btn-sm btn-outline-primary" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No claims found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
