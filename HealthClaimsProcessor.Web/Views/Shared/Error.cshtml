@{
    ViewBag.Title = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> An Error Occurred</h4>
            </div>
            <div class="card-body">
                <p class="lead">Sorry, an error occurred while processing your request.</p>
                <p class="text-muted">Please try again later or contact support if the problem persists.</p>

                <div class="mt-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                        <i class="bi bi-house-door"></i> Return to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
