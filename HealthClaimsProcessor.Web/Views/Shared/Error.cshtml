@model System.Web.Mvc.HandleErrorInfo
@{
    ViewBag.Title = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> An Error Occurred</h4>
            </div>
            <div class="card-body">
                <p class="lead">Sorry, an error occurred while processing your request.</p>

                @if (Model != null)
                {
                    <div class="alert alert-danger mt-3">
                        <strong>Controller:</strong> @Model.ControllerName<br />
                        <strong>Action:</strong> @Model.ActionName<br />
                        @if (Model.Exception != null)
                        {
                            <strong>Exception:</strong> @Model.Exception.Message
                        }
                    </div>

                    @if (HttpContext.Current.IsDebuggingEnabled && Model.Exception != null)
                    {
                        <div class="card mt-3">
                            <div class="card-header">
                                <strong>Stack Trace</strong>
                            </div>
                            <div class="card-body">
                                <pre class="mb-0" style="white-space: pre-wrap; word-wrap: break-word;">@Model.Exception.StackTrace</pre>
                            </div>
                        </div>
                    }
                }

                <div class="mt-4">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                        <i class="bi bi-house-door"></i> Return to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
