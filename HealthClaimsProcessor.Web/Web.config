<?xml version="1.0" encoding="utf-8"?>
<!--
  Web.config for HealthClaimsProcessor.Web
  ASP.NET MVC 5 application with Microsoft Enterprise Library 6.0
  Configuration includes: Logging, Exception Handling, Data Access, Validation, and Unity DI
-->
<configuration>

  <!-- ============================================================ -->
  <!-- CONFIGURATION SECTIONS                                        -->
  <!-- ============================================================ -->
  <configSections>
    <!-- Enterprise Library Configuration Sections -->
    <section name="loggingConfiguration"
             type="Microsoft.Practices.EnterpriseLibrary.Logging.Configuration.LoggingSettings, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
             requirePermission="true" />

    <section name="exceptionHandling"
             type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Configuration.ExceptionHandlingSettings, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
             requirePermission="true" />

    <section name="dataConfiguration"
             type="Microsoft.Practices.EnterpriseLibrary.Data.Configuration.DatabaseSettings, Microsoft.Practices.EnterpriseLibrary.Data, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
             requirePermission="true" />

    <section name="validation"
             type="Microsoft.Practices.EnterpriseLibrary.Validation.Configuration.ValidationSettings, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
             requirePermission="true" />

    <section name="unity"
             type="Microsoft.Practices.Unity.Configuration.UnityConfigurationSection, Unity.Configuration, Version=5.11.0.0, Culture=neutral, PublicKeyToken=6d32ff45e0ccc69f" />
  </configSections>

  <!-- ============================================================ -->
  <!-- CONNECTION STRINGS                                            -->
  <!-- ============================================================ -->
  <connectionStrings>
    <add name="HealthClaimsDB"
         connectionString="Server=(localdb)\mssqllocaldb;Database=HealthClaimsDB;Integrated Security=true;MultipleActiveResultSets=true;Connection Timeout=30"
         providerName="System.Data.SqlClient" />
    <add name="HealthClaimsDB.AuditLog"
         connectionString="Server=(localdb)\mssqllocaldb;Database=HealthClaimsDB;Integrated Security=true;MultipleActiveResultSets=true;Connection Timeout=30"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <!-- ============================================================ -->
  <!-- APP SETTINGS                                                  -->
  <!-- ============================================================ -->
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <add key="ApplicationName" value="HealthClaimsProcessor" />
    <add key="ApplicationVersion" value="1.0.0" />
    <add key="Environment" value="Development" />
    <add key="MaxClaimAmount" value="1000000.00" />
    <add key="ClaimExpirationDays" value="90" />
    <add key="EnableAuditLogging" value="true" />
    <add key="DefaultPageSize" value="25" />
    <add key="SupportEmail" value="support@healthclaims.local" />
  </appSettings>

  <!-- ============================================================ -->
  <!-- ENTERPRISE LIBRARY: DATA ACCESS APPLICATION BLOCK             -->
  <!-- ============================================================ -->
  <dataConfiguration defaultDatabase="HealthClaimsDB" />

  <!-- ============================================================ -->
  <!-- ENTERPRISE LIBRARY: LOGGING APPLICATION BLOCK                 -->
  <!-- ============================================================ -->
  <loggingConfiguration name="Logging Application Block"
                        tracingEnabled="true"
                        defaultCategory="General"
                        logWarningsWhenNoCategoriesMatch="true">

    <!-- ======== LISTENERS ======== -->
    <listeners>
      <!-- Flat File Trace Listener -->
      <add name="FlatFile TraceListener"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.TraceListeners.FlatFileTraceListener, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           listenerDataType="Microsoft.Practices.EnterpriseLibrary.Logging.Configuration.FlatFileTraceListenerData, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           fileName="C:\Logs\HealthClaims\app.log"
           header="========================================="
           footer="========================================="
           formatter="Text Formatter"
           traceOutputOptions="DateTime, Timestamp, Callstack" />

      <!-- Rolling Flat File Trace Listener -->
      <add name="Rolling FlatFile TraceListener"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.TraceListeners.RollingFlatFileTraceListener, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           listenerDataType="Microsoft.Practices.EnterpriseLibrary.Logging.Configuration.RollingFlatFileTraceListenerData, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           fileName="C:\Logs\HealthClaims\rolling.log"
           header="========================================="
           footer="========================================="
           formatter="Text Formatter"
           rollFileExistsBehavior="Increment"
           rollInterval="Day"
           rollSizeKB="10240"
           maxArchivedFiles="7"
           timeStampPattern="yyyy-MM-dd"
           traceOutputOptions="DateTime, Timestamp" />

      <!-- Database Trace Listener -->
      <add name="Database TraceListener"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Database.FormattedDatabaseTraceListener, Microsoft.Practices.EnterpriseLibrary.Logging.Database, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           listenerDataType="Microsoft.Practices.EnterpriseLibrary.Logging.Database.Configuration.FormattedDatabaseTraceListenerData, Microsoft.Practices.EnterpriseLibrary.Logging.Database, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           databaseInstanceName="HealthClaimsDB.AuditLog"
           writeLogStoredProcName="dbo.WriteAuditLog"
           addCategoryStoredProcName="dbo.AddAuditLogCategory"
           formatter="Database Formatter"
           traceOutputOptions="LogicalOperationStack, DateTime, Timestamp, ProcessId, ThreadId" />

      <!-- Event Log Trace Listener (for critical errors) -->
      <add name="EventLog TraceListener"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.TraceListeners.FormattedEventLogTraceListener, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           listenerDataType="Microsoft.Practices.EnterpriseLibrary.Logging.Configuration.FormattedEventLogTraceListenerData, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           source="HealthClaimsProcessor"
           formatter="Text Formatter"
           log="Application"
           machineName="."
           traceOutputOptions="DateTime, Timestamp, Callstack" />

      <!-- Email Trace Listener (for critical alerts) -->
      <add name="Email TraceListener"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.TraceListeners.EmailTraceListener, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           listenerDataType="Microsoft.Practices.EnterpriseLibrary.Logging.Configuration.EmailTraceListenerData, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           toAddress="ops-alerts@healthclaims.local"
           fromAddress="healthclaims-noreply@healthclaims.local"
           subjectLineStarter="HealthClaims ALERT: "
           subjectLineEnder=""
           smtpServer="smtp.healthclaims.local"
           smtpPort="25"
           formatter="Text Formatter"
           traceOutputOptions="DateTime, Timestamp" />
    </listeners>

    <!-- ======== FORMATTERS ======== -->
    <formatters>
      <add name="Text Formatter"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Formatters.TextFormatter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           template="Timestamp: {timestamp(local)}{newline}Message: {message}{newline}Category: {category}{newline}Priority: {priority}{newline}EventId: {eventid}{newline}Severity: {severity}{newline}Title: {title}{newline}Machine: {localMachine}{newline}App Domain: {localAppDomain}{newline}ProcessId: {localProcessId}{newline}Process Name: {localProcessName}{newline}Thread Name: {threadName}{newline}Win32 ThreadId: {win32ThreadId}{newline}Extended Properties: {dictionary({key} - {value}{newline})}" />

      <add name="Database Formatter"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Formatters.TextFormatter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           template="Timestamp: {timestamp(local)}{newline}Message: {message}{newline}Category: {category}{newline}Priority: {priority}{newline}Severity: {severity}{newline}Title: {title}{newline}Activity ID: {activity}{newline}Machine: {localMachine}{newline}Process: {localProcessName} [{localProcessId}]{newline}Thread: {threadName} [{win32ThreadId}]{newline}Extended Properties: {dictionary({key} - {value}{newline})}" />

      <add name="Brief Formatter"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Formatters.TextFormatter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           template="{timestamp(local)} [{severity}] {category}: {message}" />
    </formatters>

    <!-- ======== LOG FILTERS ======== -->
    <logFilters>
      <add name="Priority Filter"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Filters.PriorityFilter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           minimumPriority="1"
           maximumPriority="100" />

      <add name="LogEnabled Filter"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Filters.LogEnabledFilter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           enabled="true" />

      <add name="Category Filter"
           type="Microsoft.Practices.EnterpriseLibrary.Logging.Filters.CategoryFilter, Microsoft.Practices.EnterpriseLibrary.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
           categoryFilterMode="AllowAllExceptDenied">
        <categoryFilters>
          <add name="Debug" />
        </categoryFilters>
      </add>
    </logFilters>

    <!-- ======== CATEGORY SOURCES ======== -->
    <categorySources>
      <!-- General category - all purpose logging -->
      <add name="General" switchValue="All">
        <listeners>
          <add name="FlatFile TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
          <add name="Database TraceListener" />
        </listeners>
      </add>

      <!-- Service layer operations -->
      <add name="Service" switchValue="All">
        <listeners>
          <add name="FlatFile TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
          <add name="Database TraceListener" />
        </listeners>
      </add>

      <!-- Data access and repository operations -->
      <add name="DataAccess" switchValue="All">
        <listeners>
          <add name="FlatFile TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
          <add name="Database TraceListener" />
        </listeners>
      </add>

      <!-- Validation operations -->
      <add name="Validation" switchValue="All">
        <listeners>
          <add name="FlatFile TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
          <add name="Database TraceListener" />
        </listeners>
      </add>

      <!-- Claims Processing workflow -->
      <add name="ClaimsProcessing" switchValue="All">
        <listeners>
          <add name="FlatFile TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
          <add name="Database TraceListener" />
        </listeners>
      </add>

      <!-- Audit trail for compliance -->
      <add name="Audit" switchValue="All">
        <listeners>
          <add name="Database TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
        </listeners>
      </add>

      <!-- Security-related events -->
      <add name="Security" switchValue="All">
        <listeners>
          <add name="EventLog TraceListener" />
          <add name="Database TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
        </listeners>
      </add>

      <!-- Performance instrumentation -->
      <add name="Performance" switchValue="Warning">
        <listeners>
          <add name="Rolling FlatFile TraceListener" />
          <add name="Database TraceListener" />
        </listeners>
      </add>
    </categorySources>

    <!-- ======== SPECIAL SOURCES ======== -->
    <specialSources>
      <!-- Catches all log entries regardless of category -->
      <allEvents switchValue="All" name="All Events">
        <listeners>
          <add name="Rolling FlatFile TraceListener" />
        </listeners>
      </allEvents>

      <!-- Catches entries with no matching category source -->
      <notProcessed switchValue="All" name="Unprocessed Category">
        <listeners>
          <add name="FlatFile TraceListener" />
          <add name="Rolling FlatFile TraceListener" />
        </listeners>
      </notProcessed>

      <!-- Catches internal logging errors -->
      <errors switchValue="All" name="Logging Errors &amp; Warnings">
        <listeners>
          <add name="EventLog TraceListener" />
          <add name="FlatFile TraceListener" />
        </listeners>
      </errors>
    </specialSources>
  </loggingConfiguration>

  <!-- ============================================================ -->
  <!-- ENTERPRISE LIBRARY: EXCEPTION HANDLING APPLICATION BLOCK      -->
  <!-- ============================================================ -->
  <exceptionHandling>
    <exceptionPolicies>

      <!-- ======== SERVICE LAYER POLICY ======== -->
      <!-- Logs the exception and rethrows to preserve the original stack trace -->
      <add name="Service Layer Policy">
        <exceptionTypes>
          <add name="All Exceptions"
               type="System.Exception, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <!-- Log the exception details -->
              <add name="Service Layer Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="Service"
                   eventId="200"
                   severity="Error"
                   title="Service Layer Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <!-- Rethrow as a service exception -->
              <add name="Service Layer Rethrow Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="A service layer error occurred while processing your request. Please contact support if the problem persists."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.ServiceLayerException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="InvalidOperationException"
               type="System.InvalidOperationException, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="Service InvalidOp Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="Service"
                   eventId="201"
                   severity="Warning"
                   title="Service Layer Invalid Operation"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="Service InvalidOp Wrap Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="The requested operation is not valid in the current state of the claims processor."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.ServiceLayerException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="ArgumentException"
               type="System.ArgumentException, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="Service Argument Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="Validation"
                   eventId="202"
                   severity="Warning"
                   title="Service Layer Argument Error"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="Service Argument Wrap Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="One or more input parameters were invalid. Please verify your claim data and try again."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.ValidationException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>
        </exceptionTypes>
      </add>

      <!-- ======== DATA ACCESS POLICY ======== -->
      <!-- Logs exceptions and wraps them in a custom DataAccessException -->
      <add name="Data Access Policy">
        <exceptionTypes>
          <add name="SqlException"
               type="System.Data.SqlClient.SqlException, System.Data, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="DataAccess SQL Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="DataAccess"
                   eventId="300"
                   severity="Error"
                   title="Data Access SQL Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="DataAccess SQL Wrap Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="A database error occurred while accessing health claims data. The error has been logged for investigation."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.DataAccessException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="DbException"
               type="System.Data.Common.DbException, System.Data, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="DataAccess Db Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="DataAccess"
                   eventId="301"
                   severity="Error"
                   title="Data Access Database Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="DataAccess Db Wrap Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="A database connectivity error occurred. Please try again later or contact support."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.DataAccessException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="TimeoutException"
               type="System.TimeoutException, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="DataAccess Timeout Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="DataAccess"
                   eventId="302"
                   severity="Error"
                   title="Data Access Timeout"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="DataAccess Timeout Wrap Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="The database operation timed out while processing the health claim. Please try again."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.DataAccessException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="All Exceptions"
               type="System.Exception, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="DataAccess General Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="DataAccess"
                   eventId="399"
                   severity="Error"
                   title="Data Access Unhandled Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="DataAccess General Wrap Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.WrapHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="An unexpected error occurred in the data access layer. The error has been logged."
                   wrapExceptionType="HealthClaimsProcessor.Core.Exceptions.DataAccessException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>
        </exceptionTypes>
      </add>

      <!-- ======== GLOBAL POLICY ======== -->
      <!-- Last-resort handler: logs to event log and replaces with friendly message -->
      <add name="Global Policy">
        <exceptionTypes>
          <add name="All Exceptions"
               type="System.Exception, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <!-- Log to event log for ops visibility -->
              <add name="Global EventLog Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="General"
                   eventId="100"
                   severity="Critical"
                   title="Global Unhandled Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <!-- Replace with user-friendly exception -->
              <add name="Global Replace Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.ReplaceHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="An unexpected error has occurred in the Health Claims Processor application. Our team has been notified and is investigating. Please try again later or contact support at support@healthclaims.local for assistance."
                   replaceExceptionType="HealthClaimsProcessor.Core.Exceptions.FriendlyUserException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="SecurityException"
               type="System.Security.SecurityException, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="Global Security Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="Security"
                   eventId="101"
                   severity="Critical"
                   title="Security Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="Global Security Replace Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.ReplaceHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="You do not have the required permissions to perform this action. Please contact your administrator."
                   replaceExceptionType="HealthClaimsProcessor.Core.Exceptions.FriendlyUserException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>

          <add name="UnauthorizedAccessException"
               type="System.UnauthorizedAccessException, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="Global Unauthorized Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="Security"
                   eventId="102"
                   severity="Critical"
                   title="Unauthorized Access Exception"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
              <add name="Global Unauthorized Replace Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.ReplaceHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   exceptionMessage="Access denied. You are not authorized to access this health claims resource."
                   replaceExceptionType="HealthClaimsProcessor.Core.Exceptions.FriendlyUserException, HealthClaimsProcessor.Core" />
            </exceptionHandlers>
          </add>
        </exceptionTypes>
      </add>

      <!-- ======== VALIDATION POLICY ======== -->
      <add name="Validation Policy">
        <exceptionTypes>
          <add name="ValidationException"
               type="HealthClaimsProcessor.Core.Exceptions.ValidationException, HealthClaimsProcessor.Core"
               postHandlingAction="ThrowNewException">
            <exceptionHandlers>
              <add name="Validation Logging Handler"
                   type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging.LoggingExceptionHandler, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.Logging, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   logCategory="Validation"
                   eventId="400"
                   severity="Warning"
                   title="Claim Validation Failure"
                   formatterType="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.TextExceptionFormatter, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                   priority="5" />
            </exceptionHandlers>
          </add>
        </exceptionTypes>
      </add>
    </exceptionPolicies>
  </exceptionHandling>

  <!-- ============================================================ -->
  <!-- ENTERPRISE LIBRARY: VALIDATION APPLICATION BLOCK              -->
  <!-- Configured via DataAnnotation-style attributes on models      -->
  <!-- ============================================================ -->
  <validation>
    <type name="HealthClaimsProcessor.Core.Models.HealthClaim"
          defaultRuleset="ClaimValidation"
          assemblyName="HealthClaimsProcessor.Core">
      <ruleset name="ClaimValidation">
        <properties>
          <property name="ClaimNumber">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.NotNullValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       messageTemplate="Claim number is required."
                       name="ClaimNumber NotNull" />
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.StringLengthValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       upperBound="20"
                       lowerBound="5"
                       lowerBoundType="Inclusive"
                       upperBoundType="Inclusive"
                       messageTemplate="Claim number must be between 5 and 20 characters."
                       name="ClaimNumber Length" />
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.RegexValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       pattern="^HC-\d{4}-\d{6}$"
                       messageTemplate="Claim number must follow format HC-YYYY-NNNNNN."
                       name="ClaimNumber Format" />
          </property>
          <property name="ClaimAmount">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.RangeValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       lowerBound="0.01"
                       lowerBoundType="Inclusive"
                       upperBound="1000000.00"
                       upperBoundType="Inclusive"
                       messageTemplate="Claim amount must be between $0.01 and $1,000,000.00."
                       name="ClaimAmount Range" />
          </property>
          <property name="PatientId">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.NotNullValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       messageTemplate="Patient ID is required."
                       name="PatientId NotNull" />
          </property>
          <property name="DiagnosisCode">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.NotNullValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       messageTemplate="Diagnosis code (ICD-10) is required."
                       name="DiagnosisCode NotNull" />
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.RegexValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       pattern="^[A-Z]\d{2}(\.\d{1,4})?$"
                       messageTemplate="Diagnosis code must be a valid ICD-10 code (e.g., A01, A01.1)."
                       name="DiagnosisCode Format" />
          </property>
          <property name="ServiceDate">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.DateTimeRangeValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       lowerBound="2000-01-01T00:00:00"
                       lowerBoundType="Inclusive"
                       upperBound="2099-12-31T23:59:59"
                       upperBoundType="Inclusive"
                       messageTemplate="Service date must be between 2000 and 2099."
                       name="ServiceDate Range" />
          </property>
        </properties>
      </ruleset>
    </type>

    <type name="HealthClaimsProcessor.Core.Models.Provider"
          defaultRuleset="ProviderValidation"
          assemblyName="HealthClaimsProcessor.Core">
      <ruleset name="ProviderValidation">
        <properties>
          <property name="NPI">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.NotNullValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       messageTemplate="National Provider Identifier (NPI) is required."
                       name="NPI NotNull" />
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.RegexValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       pattern="^\d{10}$"
                       messageTemplate="NPI must be a 10-digit number."
                       name="NPI Format" />
          </property>
          <property name="TaxId">
            <validator type="Microsoft.Practices.EnterpriseLibrary.Validation.Validators.RegexValidator, Microsoft.Practices.EnterpriseLibrary.Validation, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                       pattern="^\d{2}-\d{7}$"
                       messageTemplate="Tax ID must follow format NN-NNNNNNN."
                       name="TaxId Format" />
          </property>
        </properties>
      </ruleset>
    </type>
  </validation>

  <!-- ============================================================ -->
  <!-- UNITY CONTAINER CONFIGURATION                                 -->
  <!-- ============================================================ -->
  <unity xmlns="http://schemas.microsoft.com/practices/2010/unity">

    <!-- Container Extension Registrations -->
    <sectionExtension
        type="Microsoft.Practices.EnterpriseLibrary.Common.Configuration.Unity.EnterpriseLibraryCoreExtension, Microsoft.Practices.EnterpriseLibrary.Common, Version=6.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />

    <container>
      <!-- Enterprise Library Interception Extension -->
      <extension type="Interception" />

      <!-- Lifetime Managers -->

      <!-- Repository Registrations -->
      <register type="HealthClaimsProcessor.Core.Interfaces.IClaimRepository, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Data.Repositories.ClaimRepository, HealthClaimsProcessor.Data">
        <lifetime type="perresolve" />
        <constructor>
          <param name="databaseName" value="HealthClaimsDB" />
        </constructor>
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IProviderRepository, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Data.Repositories.ProviderRepository, HealthClaimsProcessor.Data">
        <lifetime type="perresolve" />
        <constructor>
          <param name="databaseName" value="HealthClaimsDB" />
        </constructor>
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IPatientRepository, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Data.Repositories.PatientRepository, HealthClaimsProcessor.Data">
        <lifetime type="perresolve" />
        <constructor>
          <param name="databaseName" value="HealthClaimsDB" />
        </constructor>
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IAuditRepository, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Data.Repositories.AuditRepository, HealthClaimsProcessor.Data">
        <lifetime type="perresolve" />
      </register>

      <!-- Service Registrations -->
      <register type="HealthClaimsProcessor.Core.Interfaces.IClaimService, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Services.ClaimService, HealthClaimsProcessor.Services">
        <lifetime type="perresolve" />
        <interceptor type="InterfaceInterceptor" />
        <interceptionBehavior type="HealthClaimsProcessor.Core.Behaviors.LoggingInterceptionBehavior, HealthClaimsProcessor.Core" />
        <interceptionBehavior type="HealthClaimsProcessor.Core.Behaviors.ExceptionHandlingInterceptionBehavior, HealthClaimsProcessor.Core" />
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IClaimValidationService, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Services.ClaimValidationService, HealthClaimsProcessor.Services">
        <lifetime type="perresolve" />
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IClaimProcessingService, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Services.ClaimProcessingService, HealthClaimsProcessor.Services">
        <lifetime type="perresolve" />
        <interceptor type="InterfaceInterceptor" />
        <interceptionBehavior type="HealthClaimsProcessor.Core.Behaviors.LoggingInterceptionBehavior, HealthClaimsProcessor.Core" />
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IProviderService, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Services.ProviderService, HealthClaimsProcessor.Services">
        <lifetime type="perresolve" />
      </register>

      <register type="HealthClaimsProcessor.Core.Interfaces.IAuditService, HealthClaimsProcessor.Core"
                mapTo="HealthClaimsProcessor.Services.AuditService, HealthClaimsProcessor.Services">
        <lifetime type="singleton" />
      </register>

      <!-- Enterprise Library Service Registrations -->
      <register type="Microsoft.Practices.EnterpriseLibrary.ExceptionHandling.ExceptionManager, Microsoft.Practices.EnterpriseLibrary.ExceptionHandling">
        <lifetime type="singleton" />
      </register>

      <register type="Microsoft.Practices.EnterpriseLibrary.Logging.LogWriter, Microsoft.Practices.EnterpriseLibrary.Logging">
        <lifetime type="singleton" />
      </register>
    </container>
  </unity>

  <!-- ============================================================ -->
  <!-- SYSTEM.WEB                                                    -->
  <!-- ============================================================ -->
  <system.web>
    <compilation debug="true" targetFramework="4.8">
      <assemblies>
        <add assembly="System.Web.Mvc, Version=5.2.9.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
        <add assembly="System.Web.Optimization, Version=1.1.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
        <add assembly="System.Web.Routing, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
        <add assembly="System.Web.WebPages, Version=3.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
        <add assembly="System.Web.Helpers, Version=3.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" />
      </assemblies>
    </compilation>

    <authentication mode="Forms">
      <forms loginUrl="~/Account/Login"
             timeout="30"
             slidingExpiration="true"
             name=".HealthClaimsAuth"
             protection="All"
             requireSSL="false"
             path="/" />
    </authentication>

    <authorization>
      <deny users="?" />
    </authorization>

    <customErrors mode="On" defaultRedirect="~/Error">
      <error statusCode="404" redirect="~/Error/NotFound" />
      <error statusCode="403" redirect="~/Error/Forbidden" />
      <error statusCode="500" redirect="~/Error/InternalError" />
    </customErrors>

    <httpRuntime targetFramework="4.8"
                 maxRequestLength="10240"
                 executionTimeout="300"
                 enableVersionHeader="false" />

    <pages>
      <namespaces>
        <add namespace="System.Web.Helpers" />
        <add namespace="System.Web.Mvc" />
        <add namespace="System.Web.Mvc.Ajax" />
        <add namespace="System.Web.Mvc.Html" />
        <add namespace="System.Web.Optimization" />
        <add namespace="System.Web.Routing" />
        <add namespace="System.Web.WebPages" />
        <add namespace="HealthClaimsProcessor.Core.Models" />
        <add namespace="HealthClaimsProcessor.Web.ViewModels" />
      </namespaces>
    </pages>

    <sessionState mode="InProc"
                  timeout="30"
                  cookieName=".HealthClaimsSession" />

    <globalization culture="en-US"
                   uiCulture="en-US"
                   requestEncoding="utf-8"
                   responseEncoding="utf-8" />

    <httpModules>
      <add name="ApplicationInsightsWebTracking"
           type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web" />
    </httpModules>
  </system.web>

  <!-- ============================================================ -->
  <!-- SYSTEM.WEBSERVER                                              -->
  <!-- ============================================================ -->
  <system.webServer>
    <modules runAllManagedModulesForAllRequests="true">
      <remove name="FormsAuthentication" />
      <add name="FormsAuthentication"
           type="System.Web.Security.FormsAuthenticationModule"
           preCondition="" />
    </modules>

    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>

    <staticContent>
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
    </staticContent>
  </system.webServer>

